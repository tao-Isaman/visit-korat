---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import SEOHead from "../components/SEOHead.astro";
import StructuredData from "../components/StructuredData.astro";
import { getLangFromUrl } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishDate?: Date;
  keywords?: string[];
  structuredData?: { type: "website" | "attraction" | "restaurant" | "article" | "event"; data?: Record<string, any> };
}

const lang = getLangFromUrl(Astro.url);

const defaultDescriptions: Record<string, string> = {
  en: "Discover Korat (Nakhon Ratchasima) - Your complete travel guide to Thailand's Gateway to Isaan. Explore Phimai, Khao Yai, Pad Mee Korat, and more.",
  th: "เที่ยวโคราช (นครราชสีมา) - คู่มือท่องเที่ยวฉบับสมบูรณ์ ประตูสู่อีสาน สถานที่เที่ยว อาหาร เทศกาล ที่พัก",
  zh: "呵叻旅游攻略 (呵叻府) - 泰国东北部伊森大门完整旅游指南。景点、美食、节日、住宿一网打尽。",
};

const {
  title,
  description = defaultDescriptions[lang] || defaultDescriptions.en,
  image = "/images/heroes/korat-skyline.jpg",
  type = "website",
  publishDate,
  keywords = [],
  structuredData,
} = Astro.props;

const siteName: Record<string, string> = {
  en: "Visit Korat",
  th: "เที่ยวโคราช",
  zh: "呵叻旅游",
};

const fullTitle = `${title} | ${siteName[lang] || siteName.en}`;
---

<!doctype html>
<html lang={lang === "zh" ? "zh-Hans" : lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <SEOHead
      title={fullTitle}
      description={description}
      image={image}
      type={type}
      publishDate={publishDate}
      keywords={keywords}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Thai:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    {structuredData ? (
      <StructuredData type={structuredData.type} data={structuredData.data} />
    ) : (
      <StructuredData type="website" />
    )}
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollToTop />
  </body>
</html>
