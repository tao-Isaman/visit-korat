---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import InfoBox from "../../../components/InfoBox.astro";
import { getCollection, render } from "astro:content";
import { supportedLangs, useTranslations, getLocalizedPath } from "../../../i18n/utils";
import { getSlug } from "../../../i18n/content";
import type { Lang } from "../../../i18n/ui";

export async function getStaticPaths() {
  const food = await getCollection("food");
  return food.map((entry) => ({
    params: { lang: entry.data.lang, slug: getSlug(entry.id) },
    props: { entry },
  }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const { entry } = Astro.props;
const { Content } = await render(entry);

const infoItems = [
  entry.data.priceRange && { label: "Price Range", value: entry.data.priceRange, icon: "payments" },
  entry.data.address && { label: "Address", value: entry.data.address, icon: "location_on" },
  entry.data.openingHours && { label: "Opening Hours", value: entry.data.openingHours, icon: "schedule" },
  entry.data.mustTry.length > 0 && { label: "Must Try", value: entry.data.mustTry.join(", "), icon: "star" },
].filter(Boolean) as { label: string; value: string; icon: string }[];
---

<Layout title={entry.data.title} description={entry.data.description}>
  <Hero title={entry.data.title} image={entry.data.image} height="medium" />

  <article class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm text-gray-500">
        <a href={getLocalizedPath(lang, "/")} class="hover:text-primary-600">{t("nav.home")}</a>
        <span class="mx-2">/</span>
        <a href={getLocalizedPath(lang, "/food")} class="hover:text-primary-600">{t("nav.food")}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{entry.data.title}</span>
      </nav>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 prose prose-lg max-w-none prose-headings:text-gray-900 prose-p:text-gray-700 prose-a:text-primary-600">
          <Content />
        </div>
        <aside class="space-y-6">
          {infoItems.length > 0 && <InfoBox items={infoItems} />}
          {entry.data.tags.length > 0 && (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Tags</h3>
              <div class="flex flex-wrap gap-2">
                {entry.data.tags.map((tag: string) => (
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded-full">{tag}</span>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </article>
</Layout>
