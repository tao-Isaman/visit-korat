---
import Layout from "../../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { supportedLangs, useTranslations, getLocalizedPath } from "../../../i18n/utils";
import { getSlug } from "../../../i18n/content";
import type { Lang } from "../../../i18n/ui";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((entry) => ({
    params: { lang: entry.data.lang, slug: getSlug(entry.id) },
    props: { entry },
  }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <div class="relative h-[40vh] min-h-[300px]">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${entry.data.image}')`}>
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
    </div>
  </div>

  <article class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-gray-500">
        <a href={getLocalizedPath(lang, "/")} class="hover:text-primary-600">{t("nav.home")}</a>
        <span class="mx-2">/</span>
        <a href={getLocalizedPath(lang, "/blog")} class="hover:text-primary-600">{t("nav.blog")}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{entry.data.title}</span>
      </nav>

      <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3">{entry.data.title}</h1>
        <div class="flex items-center gap-4 text-sm text-gray-500">
          <span>{entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
          <span>By {entry.data.author}</span>
        </div>
        {entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-3">
            {entry.data.tags.map((tag: string) => (
              <span class="px-3 py-1 bg-primary-50 text-primary-700 text-sm font-medium rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-p:text-gray-700 prose-a:text-primary-600 prose-strong:text-gray-900">
        <Content />
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <a href={getLocalizedPath(lang, "/blog")} class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors">
          <span class="material-symbols-outlined text-[18px]">arrow_back</span>
          {t("general.backTo")} {t("nav.blog")}
        </a>
      </div>
    </div>
  </article>
</Layout>
