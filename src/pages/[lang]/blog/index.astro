---
import Layout from "../../../layouts/Layout.astro";
import HeroSplit from "../../../components/HeroSplit.astro";
import { getCollection } from "astro:content";
import { supportedLangs, useTranslations, getLocalizedPath } from "../../../i18n/utils";
import { filterByLang, getSlug } from "../../../i18n/content";
import type { Lang } from "../../../i18n/ui";

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const posts = filterByLang(await getCollection("blog"), lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={t("nav.blog")}>
  <HeroSplit
    title={t("nav.blog")}
    subtitle={t("home.blog.subtitle")}
    image="/images/heroes/khao-yai-forest.jpg"
  />

  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
      {posts.map((post) => (
        <a
          href={getLocalizedPath(lang, `/blog/${getSlug(post.id)}`)}
          class="group flex flex-col sm:flex-row gap-0 bg-white rounded-[22px] overflow-hidden shadow-sm hover:shadow-lg transition-all border border-gray-100"
        >
          <div class="sm:w-64 shrink-0 aspect-video sm:aspect-[4/3] overflow-hidden">
            <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-5 sm:p-6 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-sm text-gray-500">
                {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </span>
              {post.data.tags.slice(0, 2).map((tag: string) => (
                <span class="px-2 py-0.5 bg-primary-50 text-primary-700 text-xs font-medium rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors">{post.data.title}</h2>
            <p class="mt-2 text-gray-600 line-clamp-2">{post.data.description}</p>
            <span class="mt-3 text-primary-600 font-semibold text-sm inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              {t("general.readMore")}
              <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
