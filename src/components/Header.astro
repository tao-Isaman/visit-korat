---
import { getLangFromUrl, useTranslations, getLocalizedPath, switchLang } from "../i18n/utils";
import { languages, type Lang } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { label: t("nav.home"), href: getLocalizedPath(lang, "/") },
  { label: t("nav.attractions"), href: getLocalizedPath(lang, "/attractions") },
  { label: t("nav.food"), href: getLocalizedPath(lang, "/food") },
  { label: t("nav.neighborhoods"), href: getLocalizedPath(lang, "/neighborhoods") },
  { label: t("nav.festivals"), href: getLocalizedPath(lang, "/festivals") },
  { label: t("nav.plan"), href: getLocalizedPath(lang, "/plan-your-visit") },
  { label: t("nav.blog"), href: getLocalizedPath(lang, "/blog") },
];

const currentPath = Astro.url.pathname;
const langEntries = Object.entries(languages) as [Lang, string][];
---

<header id="site-header" class="bg-white/95 backdrop-blur-md sticky top-0 z-50 transition-all duration-300 h-20 border-b border-gray-100">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 h-full">
    <div class="flex items-center justify-between h-full">
      <!-- Logo -->
      <a href={getLocalizedPath(lang, "/")} class="flex items-center gap-2.5 shrink-0">
        <span class="material-symbols-outlined text-primary-700 text-[28px]">temple_buddhist</span>
        <div class="leading-tight">
          <span class="text-xl font-extrabold text-primary-700">Visit</span>
          <span class="text-xl font-extrabold text-accent-500">Korat</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {
          navItems.map((item) => {
            const isActive = currentPath === item.href ||
              (item.href !== getLocalizedPath(lang, "/") && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  "px-3 py-2 text-sm font-medium transition-colors relative",
                  isActive
                    ? "text-primary-700 font-semibold"
                    : "text-gray-600 hover:text-primary-700",
                ]}
              >
                {item.label}
                {isActive && (
                  <span class="absolute bottom-0 left-3 right-3 h-[3px] bg-primary-600 rounded-full" />
                )}
              </a>
            );
          })
        }
      </nav>

      <!-- Right: Language + Mobile Menu -->
      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <div class="relative" id="lang-switcher">
          <button
            id="lang-btn"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors"
          >
            <span class="material-symbols-outlined text-[20px]">language</span>
            <span class="hidden sm:inline">{languages[lang]}</span>
            <span class="material-symbols-outlined text-[16px]">expand_more</span>
          </button>
          <div
            id="lang-dropdown"
            class="hidden absolute right-0 top-full mt-1 bg-white rounded-xl shadow-lg border border-gray-100 py-1 min-w-[140px] z-50"
          >
            {
              langEntries.map(([code, name]) => (
                <a
                  href={switchLang(Astro.url, code)}
                  class:list={[
                    "block px-4 py-2 text-sm transition-colors",
                    code === lang
                      ? "text-primary-700 font-semibold bg-primary-50"
                      : "text-gray-700 hover:bg-gray-50",
                  ]}
                >
                  {name}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
          aria-label="Toggle menu"
        >
          <span class="material-symbols-outlined text-[24px]" id="menu-icon">menu</span>
        </button>
      </div>
    </div>
  </div>

</header>

<!-- Mobile Nav Overlay - outside header to avoid clipping -->
<div id="mobile-menu" class="hidden fixed inset-0 top-16 bg-white z-[45] lg:hidden overflow-y-auto">
  <nav class="max-w-lg mx-auto px-6 py-6 space-y-1">
    {
      navItems.map((item) => {
        const isActive = currentPath === item.href ||
          (item.href !== getLocalizedPath(lang, "/") && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              "block px-4 py-3 rounded-xl text-base font-medium transition-colors",
              isActive
                ? "bg-primary-50 text-primary-700 font-semibold"
                : "text-gray-700 hover:bg-gray-50",
            ]}
          >
            {item.label}
          </a>
        );
      })
    }
    <div class="border-t border-gray-100 pt-4 mt-4">
      <p class="px-4 text-xs text-gray-400 uppercase tracking-wider mb-2">Language</p>
      {
        langEntries.map(([code, name]) => (
          <a
            href={switchLang(Astro.url, code)}
            class:list={[
              "block px-4 py-2.5 rounded-xl text-sm transition-colors",
              code === lang
                ? "text-primary-700 font-semibold bg-primary-50"
                : "text-gray-700 hover:bg-gray-50",
            ]}
          >
            {name}
          </a>
        ))
      }
    </div>
  </nav>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var btn = document.getElementById("mobile-menu-btn");
    var menu = document.getElementById("mobile-menu");
    var icon = document.getElementById("menu-icon");

    if (btn && menu) {
      btn.addEventListener("click", function (e) {
        e.stopPropagation();
        var isOpen = !menu.classList.contains("hidden");
        menu.classList.toggle("hidden");
        if (icon) icon.textContent = isOpen ? "menu" : "close";
      });
    }

    // Language dropdown
    var langBtn = document.getElementById("lang-btn");
    var langDrop = document.getElementById("lang-dropdown");
    if (langBtn && langDrop) {
      langBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        langDrop.classList.toggle("hidden");
      });
      document.addEventListener("click", function () {
        langDrop.classList.add("hidden");
      });
    }

    // Header shrink on scroll
    var header = document.getElementById("site-header");
    if (header) {
      window.addEventListener("scroll", function () {
        if (window.scrollY > 50) {
          header.classList.add("header-shrink");
          header.classList.remove("h-20");
        } else {
          header.classList.remove("header-shrink");
          header.classList.add("h-20");
        }
      });
    }
  });
</script>
