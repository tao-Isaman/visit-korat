---
interface Props {
  title: string;
  description: string;
  image: string;
  dateRange: string;
  location: string;
  href: string;
}

const { title, description, image, dateRange, location, href } = Astro.props;
---

<a href={href} class="group block">
  <div class="rounded-[10px] overflow-hidden aspect-[4/3] max-h-60">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>
  <div class="pt-4 max-w-[200px]">
    <h3 class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2">
      {title}
    </h3>
    <div class="mt-2 space-y-1">
      <div class="flex items-center gap-2 text-sm text-gray-500">
        <span class="material-symbols-outlined text-[16px]">calendar_today</span>
        <span>{dateRange}</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-gray-500">
        <span class="material-symbols-outlined text-[16px]">location_on</span>
        <span class="line-clamp-1">{location}</span>
      </div>
    </div>
  </div>
</a>
