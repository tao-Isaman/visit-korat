---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  categories?: string[];
  activeCategory?: string;
  basePath: string;
}

const { categories = [], activeCategory = "all", basePath } = Astro.props;
---

<div class="sticky top-16 z-30 bg-white shadow-sm border-b border-gray-100 py-4">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Search Input -->
    <div class="flex items-center gap-4 mb-3">
      <div class="flex-1 relative max-w-lg">
        <input
          type="text"
          placeholder={t("general.search")}
          class="w-full pl-4 pr-12 py-2.5 rounded-full border border-gray-200 text-sm focus:outline-none focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all"
          id="search-input"
        />
        <button class="absolute right-1 top-1 w-8 h-8 rounded-full bg-primary-600 text-white flex items-center justify-center hover:bg-primary-700 transition-colors shadow-sm">
          <span class="material-symbols-outlined text-[18px]">search</span>
        </button>
      </div>
    </div>

    <!-- Category Chips -->
    {categories.length > 0 && (
      <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-1">
        <button
          class:list={[
            "filter-btn shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors",
            activeCategory === "all"
              ? "bg-primary-600 text-white"
              : "bg-gray-100 text-gray-600 hover:bg-primary-50 hover:text-primary-700",
          ]}
          data-category="all"
        >
          {t("general.all")}
        </button>
        {categories.map((cat) => (
          <button
            class:list={[
              "filter-btn shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors",
              activeCategory === cat
                ? "bg-primary-600 text-white"
                : "bg-gray-100 text-gray-600 hover:bg-primary-50 hover:text-primary-700",
            ]}
            data-category={cat}
          >
            {cat.split("-").map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ")}
          </button>
        ))}
      </div>
    )}
  </div>
</div>
