---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, subtitle, align = "center" } = Astro.props;
---

<div class:list={["mb-10", align === "center" ? "text-center" : ""]}>
  <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900">{title}</h2>
  {subtitle && (
    <p class:list={["mt-3 text-lg text-gray-500", align === "center" && "mx-auto max-w-2xl"]}>
      {subtitle}
    </p>
  )}
</div>
