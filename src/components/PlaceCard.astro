---
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
  category?: string;
  badge?: string;
  size?: "normal" | "large";
}

const { title, description, image, href, category, badge, size = "normal" } = Astro.props;

const categoryColors: Record<string, string> = {
  temple: "bg-amber-100 text-amber-800",
  historical: "bg-orange-100 text-orange-800",
  nature: "bg-green-100 text-green-800",
  museum: "bg-purple-100 text-purple-800",
  market: "bg-pink-100 text-pink-800",
  landmark: "bg-blue-100 text-blue-800",
  "street-food": "bg-red-100 text-red-800",
  restaurant: "bg-teal-100 text-teal-800",
  cafe: "bg-cyan-100 text-cyan-800",
  "local-dish": "bg-yellow-100 text-yellow-800",
};
---

<a
  href={href}
  class:list={[
    "group block bg-white overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100",
    size === "large" ? "rounded-[22px]" : "rounded-xl",
  ]}
>
  <div class:list={[
    "overflow-hidden relative",
    size === "large" ? "aspect-[16/9] max-h-[220px]" : "aspect-[16/10]",
  ]}>
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    {category && (
      <span class:list={["absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-semibold", categoryColors[category] || "bg-gray-100 text-gray-800"]}>
        {category.replace("-", " ")}
      </span>
    )}
    {badge && (
      <span class="absolute top-3 right-3 bg-accent-500 text-white px-2.5 py-1 rounded-full text-xs font-semibold">
        {badge}
      </span>
    )}
  </div>
  <div class:list={[
    size === "large" ? "px-5 py-4" : "p-4",
  ]}>
    <h3 class="font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-1">
      {title}
    </h3>
    <p class="mt-1 text-sm text-gray-600 line-clamp-2">{description}</p>
  </div>
</a>
