---
/**
 * Split hero like visit.bangkok.go.th — image on left (47%), dark content on right (53%)
 */
interface Props {
  title: string;
  titleAccent?: string;
  subtitle?: string;
  image: string;
}

const { title, titleAccent, subtitle, image } = Astro.props;
---

<section class="relative">
  <div class="flex flex-col md:flex-row min-h-[50vh]">
    <!-- Image side -->
    <div class="md:w-[47%] relative">
      <div class="aspect-[4/3] md:aspect-auto md:absolute md:inset-0">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Content side -->
    <div class="md:w-[53%] bg-dark flex items-center">
      <div class="px-8 md:px-16 lg:px-20 py-12 md:py-16 max-w-2xl">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
          {title}
          {titleAccent && (
            <span class="text-primary-400"> {titleAccent}</span>
          )}
        </h1>
        {subtitle && (
          <p class="mt-6 text-lg text-gray-300 leading-relaxed">{subtitle}</p>
        )}
        <slot />
      </div>
    </div>
  </div>
</section>
